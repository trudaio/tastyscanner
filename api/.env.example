# TastyTrade Credentials (from TastyTrade → Settings → API Tokens)
TASTY_CLIENT_SECRET=your_40_char_hex_client_secret
TASTY_REFRESH_TOKEN=eyJhbGci...your_refresh_token_jwt

# API Security — all /api/* endpoints require X-API-Key header
# Leave empty to disable auth (dev mode only)
API_KEY=your_secret_api_key_here

# Server
PORT=3001
