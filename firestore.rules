rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own document and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{subcollection=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Technical indicators (RSI/BB/ATR) — read-only for authenticated users
    // Written by computeTechnicals Cloud Function (admin SDK bypasses rules)
    match /marketTechnicals/{ticker} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Economic Calendar events — read-only; writes only via seedEconomicEvents callable
    match /economicEvents/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // System alerts (calendar seed warnings, reconcile mismatches) — read + ack only
    match /system_alerts/{alertId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledgedAt', 'acknowledgedBy']);
      allow create, delete: if false;
    }

    // Feature flags (kill-switches) — read-only; writes only via Firestore console
    match /featureFlags/{flagId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
